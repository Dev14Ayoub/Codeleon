{
  "id": "bootstrap-site",
  "name": "Bootstrap Website",
  "description": "A responsive Bootstrap landing page with no build step.",
  "language": "HTML",
  "category": "Web",
  "runtime": "Browser",
  "packageManager": "CDN",
  "defaultCommand": "Static preview",
  "runnable": true,
  "preview": true,
  "services": [],
  "tags": ["html", "css", "bootstrap", "preview"],
  "files": [
    {
      "path": "index.html",
      "content": "<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Bootstrap Starter</title>\n  <link href=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css\" rel=\"stylesheet\" />\n  <link href=\"styles.css\" rel=\"stylesheet\" />\n</head>\n<body>\n  <nav class=\"navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary\">\n    <div class=\"container\"><a class=\"navbar-brand\" href=\"#\">Codeleon Bootstrap</a></div>\n  </nav>\n  <main class=\"container py-5\">\n    <div class=\"row align-items-center g-4\">\n      <section class=\"col-lg-7\">\n        <p class=\"text-info text-uppercase small fw-semibold\">Professional starter</p>\n        <h1 class=\"display-4 fw-bold\">Ship a responsive page fast.</h1>\n        <p class=\"lead text-secondary\">Bootstrap is loaded from CDN and ready for preview.</p>\n        <button class=\"btn btn-info fw-semibold\">Get started</button>\n      </section>\n      <section class=\"col-lg-5\"><div class=\"panel p-4\">Edit this card in Codeleon.</div></section>\n    </div>\n  </main>\n</body>\n</html>\n"
    },
    {
      "path": "styles.css",
      "content": "body { background: #09090b; color: #f8fafc; }\n.panel { min-height: 220px; border: 1px solid #334155; border-radius: 8px; background: linear-gradient(135deg, #111827, #0f172a); }\n"
    }
  ]
}
