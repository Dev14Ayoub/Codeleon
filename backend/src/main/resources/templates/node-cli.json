{
  "id": "node-cli",
  "name": "Node CLI",
  "description": "A small Node.js command-line starter with npm scripts.",
  "language": "JavaScript",
  "category": "CLI/Scripting",
  "runtime": "Node 20",
  "packageManager": "npm",
  "defaultCommand": "npm install && npm test",
  "runnable": true,
  "preview": false,
  "services": [],
  "tags": ["node", "javascript", "cli"],
  "files": [
    { "path": "package.json", "content": "{\"type\":\"module\",\"scripts\":{\"start\":\"node src/index.js\",\"test\":\"node test/smoke.test.js\"},\"dependencies\":{},\"devDependencies\":{}}\n" },
    { "path": "src/index.js", "content": "export function greet(name = 'Codeleon') {\n  return `Hello, ${name}`;\n}\n\nconsole.log(greet(process.argv[2]));\n" },
    { "path": "test/smoke.test.js", "content": "import assert from 'node:assert/strict';\nimport { greet } from '../src/index.js';\n\nassert.equal(greet('Node'), 'Hello, Node');\nconsole.log('node cli smoke ok');\n" }
  ]
}
