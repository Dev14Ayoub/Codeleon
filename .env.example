# =============================================================
# Codeleon root environment variables (dev only)
# Copy to .env and adjust. Never commit .env.
# =============================================================

# Postgres
POSTGRES_DB=codeleon
POSTGRES_USER=codeleon
POSTGRES_PASSWORD=codeleon_dev_pwd
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Backend (Spring Boot)
BACKEND_PORT=8080
JWT_SECRET=replace_me_with_a_long_random_string_min_64_chars_for_HS256_security
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Qdrant (vector store) - profile: ai
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333

# Ollama (local LLM runtime) - profile: ai
# KEEP_ALIVE=0 unloads the model from RAM between requests (recommended on 8 GB machines).
# Set to "5m" or "30m" if you have spare RAM and want lower per-request latency.
OLLAMA_PORT=11434
OLLAMA_URL=http://localhost:11434
OLLAMA_KEEP_ALIVE=0
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_CHAT_MODEL=qwen2.5-coder:0.5b
OLLAMA_EMBED_MODEL=nomic-embed-text
