# =============================================================
# Codeleon root environment variables (dev only)
# Copy to .env and adjust. Never commit .env.
# =============================================================

# Postgres
# Host port is 5433 to avoid colliding with a native Windows Postgres install
# that may already be running on 5432. The container always listens on 5432
# internally; only the host-side mapping changes.
POSTGRES_DB=codeleon
POSTGRES_USER=codeleon
POSTGRES_PASSWORD=codeleon_dev_pwd
POSTGRES_PORT=5433

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Backend (Spring Boot)
BACKEND_PORT=8080
JWT_SECRET=replace_me_with_a_long_random_string_min_64_chars_for_HS256_security
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Qdrant (vector store) - profile: ai
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333

# Ollama (local LLM runtime) - profile: ai
# KEEP_ALIVE keeps the model resident between requests. 5m avoids a cold
#   disk reload on every question during a demo; set to 0 to reclaim the
#   ~1.2 GB of RAM when you are not using the assistant.
# MAX_LOADED_MODELS=2 lets the chat model and the embed model stay loaded
#   together, so a RAG query does not evict one to load the other every time.
# CHAT_MODEL: qwen2.5-coder:1.5b is the sweet spot for an 8 GB CPU box —
#   code-tuned, ~1.2 GB resident. Drop to :0.5b if RAM is tight.
OLLAMA_PORT=11434
OLLAMA_URL=http://localhost:11434
OLLAMA_KEEP_ALIVE=5m
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_CHAT_MODEL=qwen2.5-coder:1.5b
OLLAMA_EMBED_MODEL=nomic-embed-text

# OAuth2 social login (optional — leave any pair blank to disable that provider)
# GitHub: https://github.com/settings/developers > New OAuth App
#   Homepage URL = http://localhost:5173
#   Callback URL = http://localhost:8080/api/v1/login/oauth2/code/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Google: https://console.cloud.google.com/apis/credentials > Create Credentials > OAuth client ID (Web application)
#   Authorized JavaScript origins = http://localhost:5173
#   Authorized redirect URIs      = http://localhost:8080/api/v1/login/oauth2/code/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin bootstrap (optional)
# When set, the backend promotes the matching account to ADMIN on every boot.
# Useful for the very first admin; subsequent role changes go through /admin.
CODELEON_BOOTSTRAP_ADMIN_EMAIL=
